{
  "browser": {
    "browserName": "chromium",
    "userDataDir": "/opt/data/hermes-profiles/herresearch/booking-playwright-user-data",
    "launchOptions": {
      "headless": false,
      "chromiumSandbox": false,
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage"
      ]
