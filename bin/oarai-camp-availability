#!/usr/bin/env node
'use strict';

const path = require('path');
const { checkAvailability } = require('../src/oaraiCampAvailability');

// ── CLI argument parsing ─────────────────────────────────────────────────────
function parseArgs(argv) {
  const args = {};
  for (let i = 2; i < argv.length; i++) {
    if (argv[i] === '--input' && argv[i + 1]) {
      // Try to parse as JSON string or file path
      const val = argv[++i];
      if (val.startsWith('{')) {
        args.input = JSON.parse(val);
      } else {
        const fs = require('fs');
        args.input = JSON.parse(fs.readFileSync(val, 'utf-8'));
      }
    } else if (argv[i] === '--artifact-dir' && argv[i + 1]) {
      args.artifact_dir = argv[++i];
    } else if (argv[i] === '--help' || argv[i] === '-h') {
      args.help = true;
    }
  }
  return args;
}

function printUsage() {
  console.log(`
Oarai Camp Availability CLI
===========================

Usage:
  oarai-camp-availability --input '{ "checkin": "2026-06-27", "checkout": "2026-06-28", "site_type": "free_site" }'
  oarai-camp-availability --input /path/to/input.json
  oarai-camp-availability --input '{...}' --artifact-dir /tmp/artifacts

Input JSON schema:
{
  "checkin": "YYYY-MM-DD",
  "checkout": "YYYY-MM-DD",
  "site_type": "free_site",          # optional, default: "free_site"
  "timeout_seconds": 30              # optional, default: 30
}

Output: JSON to stdout with availability status for each date.
`.trim());
}

async function main() {
  const args = parseArgs(process.argv);

  if (args.help) {
    printUsage();
    process.exit(0);
  }

  if (!args.input) {
    console.error('Error: --input is required.');
    printUsage();
    process.exit(1);
  }

  const result = await checkAvailability({
    checkin: args.input.checkin,
    checkout: args.input.checkout,
    site_type: args.input.site_type || 'free_site',
    timeout_seconds: args.input.timeout_seconds || 30,
    artifact_dir: args.artifact_dir || null,
  });

  process.stdout.write(JSON.stringify(result, null, 2) + '\n');
}

main().catch((err) => {
  console.error(JSON.stringify({ error: err.message }, null, 2));
  process.exit(1);
});
